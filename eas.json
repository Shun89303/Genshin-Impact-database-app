{
	"cli": {
		"version": ">= 18.1.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"API_URL": "https://genshin.jmp.blue"
			}
		},
		"production": {
			"autoIncrement": true,
			"android": {
				"buildType": "apk"
			},
			"env": {
				"API_URL": "https://genshin.jmp.blue"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
